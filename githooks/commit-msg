#!/usr/bin/env bash
# CueMe commit-msg hook — enforce Conventional Commits.
# release tooling parses these; a wrong type breaks versioning. Don't bypass.
set -euo pipefail

msg_file="$1"
subject="$(head -1 "$msg_file")"

# allow merge/revert/fixup commits
case "$subject" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

# type(scope)!: description   — scope optional, ! optional
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9_.-]+\))?!?: .+'
if ! printf '%s' "$subject" | grep -qE "$pattern"; then
  echo "✗ commit-msg: subject não segue Conventional Commits."
  echo "  recebido: $subject"
  echo "  esperado: <type>(scope): descrição   (type ∈ feat|fix|docs|refactor|perf|test|build|ci|chore|revert)"
  exit 1
fi
exit 0
